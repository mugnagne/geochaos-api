rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['coins', 'highScore', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 4
        && data.coins is number
        && data.highScore is number
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidUserCard(data) {
      return data.keys().hasAll(['countryName', 'obtainedAt', 'count']) 
        && data.keys().size() == 3
        && data.countryName is string
        && data.countryName.size() <= 100
        && data.obtainedAt is number
        && data.count is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow list: if false; // Users cannot list other users
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && incoming().coins >= 0
        && incoming().highScore >= 0;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['coins', 'highScore', 'updatedAt'])
        && incoming().updatedAt == request.time
        && incoming().coins is number
        && incoming().coins >= 0
        && incoming().highScore is number
        && incoming().highScore >= 0;
    }

    match /users/{userId}/cards/{cardId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId) && isValidId(cardId);
      allow list: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && isValidId(userId) && isValidId(cardId)
        && isValidUserCard(incoming())
        && incoming().count >= 1;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId) && isValidId(cardId)
        && incoming().diff(existing()).affectedKeys().hasOnly(['count', 'obtainedAt'])
        && incoming().count is number
        && incoming().count >= existing().count;
    }
  }
}
